# MedVerify API Configuration
# Copy this file to .env and fill in the values:  cp .env.example .env

# =============================================================================
# Neo4j (REQUIRED)
# =============================================================================
# Provision a free instance at https://neo4j.com/cloud/aura-free/ or run the
# Docker demo (`make demo`) which seeds a local Neo4j with a 5K-edge subset.
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# =============================================================================
# Entity Extraction (GLiNER)
# =============================================================================
# Default is the biomedical-tuned variant (clinical recall on terms like
# "active bleeding", "myocardial infarction"). ~1-2 GB on first download.
# Alternatives:
#   urchade/gliner_medium-v2.1        (general, ~500 MB)
#   urchade/gliner_large-v2.1         (general, larger)
# GLINER_MODEL=Ihor/gliner-biomed-bi-large-v1.0
# GLINER_THRESHOLD=0.5

# =============================================================================
# LLM Predicate Fallback (OPTIONAL)
# =============================================================================
# Fires only when regex rules can't classify the asserted predicate. Leave the
# auth keys empty to disable; the verifier degrades gracefully and falls back
# to PARTIAL verdicts on ambiguous claims.
#
# Two auth modes (Bedrock takes precedence if both are set):
#
#  A) Direct Anthropic API
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-haiku-4-5
#
#  B) AWS Bedrock (preferred for AWS-hosted deployments)
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_REGION=us-east-1
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
#
# Shared knobs:
# LLM_FALLBACK_ENABLED=true
# LLM_TIMEOUT_SECONDS=8.0
# LLM_MIN_CONFIDENCE=0.6

# =============================================================================
# API Settings
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Rate limiting (per-client, per-minute)
RATE_LIMIT_PER_MINUTE=60

# API key auth (JSON list, empty list = public access)
# API_KEYS=["key1","key2"]

# CORS origins.
# IMPORTANT: pydantic-settings parses List[str] as JSON, NOT comma-separated.
# Use square-bracket JSON form, e.g.:
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8501"]
