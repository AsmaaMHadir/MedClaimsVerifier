# MedVerify API Configuration
# Copy this file to .env and fill in the values

# Entity Extraction (GLiNER)
# Default is the general-purpose medium model. Biomedical alternatives:
#   Ihor/gliner-biomed-bi-large-v1.0   (clinical-tuned, larger)
#   urchade/gliner_large-v2.1          (general, larger)
# GLINER_MODEL=urchade/gliner_medium-v2.1
# GLINER_THRESHOLD=0.5

# LLM predicate fallback (only fires when regex rules return NONE).
# Leave ANTHROPIC_API_KEY empty to disable; the verifier degrades gracefully.
# ANTHROPIC_API_KEY=
# LLM_FALLBACK_ENABLED=true
# LLM_MODEL=claude-haiku-4-5
# LLM_TIMEOUT_SECONDS=6.0
# LLM_MIN_CONFIDENCE=0.6

# Neo4j Aura
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# API Key Authentication (comma-separated, leave empty for public access)
# API_KEYS=key1,key2

# CORS Origins (comma-separated)
# CORS_ORIGINS=http://localhost:8501,http://localhost:3000
